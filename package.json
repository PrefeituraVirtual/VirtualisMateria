{
  "name": "materia_virtualis_frontend",
  "version": "1.0.0",
  "description": "Frontend Next.js para Materia Virtualis - Sistema de Assistente Legislativo com IA",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4001",
    "build": "next build",
    "build:static": "next build && next export",
    "start": "next start -p 4001",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "export": "next export",
    "deploy": "npm run build:static",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "jest:coverage": "jest --coverage",
    "validate-bundle": "node scripts/validate-bundle-size.js",
    "validate-bundle:verbose": "node scripts/validate-bundle-size.js --verbose",
    "perf-check": "npm run build && npm run validate-bundle",
    "analyze": "ANALYZE=true npm run build",
    "analyze:server": "BUNDLE_ANALYZE=server npm run build",
    "analyze:browser": "BUNDLE_ANALYZE=browser npm run build",
    "build:stats": "bash scripts/build-stats.sh"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-toast": "^1.2.15",
    "@syncfusion/ej2-data": "^25.2.0",
    "@syncfusion/ej2-react-buttons": "^25.2.0",
    "@syncfusion/ej2-react-calendars": "^25.2.0",
    "@syncfusion/ej2-react-documenteditor": "^25.2.0",
    "@syncfusion/ej2-react-dropdowns": "^25.2.0",
    "@syncfusion/ej2-react-inputs": "^25.2.0",
    "@syncfusion/ej2-react-lists": "^25.2.0",
    "@syncfusion/ej2-react-navigations": "^25.2.0",
    "@syncfusion/ej2-react-popups": "^25.2.0",
    "@syncfusion/ej2-react-richtexteditor": "^25.2.0",
    "@syncfusion/ej2-react-splitbuttons": "^25.2.0",
    "@tanstack/react-query": "^5.90.9",
    "@types/dompurify": "^3.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "date-fns": "^3.0.0",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.23.24",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.553.0",
    "next": "^16.1.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.4.0",
    "react-markdown": "^9.0.0",
    "recharts": "^3.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@next/bundle-analyzer": "^16.1.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.22",
    "critters": "^0.0.23",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
