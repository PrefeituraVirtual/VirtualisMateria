# ===========================================
# Materia Virtualis Frontend - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values

# ===========================================
# Core Configuration
# ===========================================

# URL da API Backend (para requisicoes diretas)
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL do Frontend (para redirecionamentos)
FRONTEND_URL=http://localhost:4001

# URL publica do site (para canonical URLs e sitemap)
NEXT_PUBLIC_SITE_URL=https://seu-dominio.com.br

# Modo de construcao (dev/static)
NEXT_PUBLIC_BUILD_MODE=dev

# Ambiente (development/production)
NODE_ENV=development

# ===========================================
# Security Configuration
# ===========================================

# Enable Content Security Policy headers
NEXT_PUBLIC_ENABLE_CSP=true

# Enable client-side rate limiting
NEXT_PUBLIC_RATE_LIMIT_ENABLED=true

# Enable CSRF protection for forms
NEXT_PUBLIC_CSRF_ENABLED=true

# Enable encrypted token storage
NEXT_PUBLIC_SECURE_STORAGE=true

# ===========================================
# Rate Limiting Configuration
# ===========================================
# Values are requests per minute

# General API rate limit
NEXT_PUBLIC_API_RATE_LIMIT=60

# Chatbot message rate limit
NEXT_PUBLIC_CHAT_RATE_LIMIT=10

# File upload rate limit
NEXT_PUBLIC_UPLOAD_RATE_LIMIT=5

# AI analysis rate limit (DeepSeek R1)
NEXT_PUBLIC_ANALYSIS_RATE_LIMIT=3

# ===========================================
# CSP Configuration
# ===========================================

# CSP report URI (optional, for violation reports)
# NEXT_PUBLIC_CSP_REPORT_URI=/api/csp-report

# Additional allowed script sources (comma-separated)
# NEXT_PUBLIC_CSP_SCRIPT_SRC=

# Additional allowed connect sources (comma-separated)
# NEXT_PUBLIC_CSP_CONNECT_SRC=

# ===========================================
# Logging Configuration
# ===========================================

# Enable security event logging
NEXT_PUBLIC_SECURITY_LOGGING=true

# Security log endpoint (production only)
# NEXT_PUBLIC_SECURITY_LOG_ENDPOINT=/api/security/log

# ===========================================
# Feature Flags
# ===========================================

# Enable AI features
NEXT_PUBLIC_ENABLE_AI=true

# Enable transcription features
NEXT_PUBLIC_ENABLE_TRANSCRIPTION=true

# Enable admin dashboard
NEXT_PUBLIC_ENABLE_ADMIN=true
